# Produção:   https://app.ajornada.top/path
URL_APP_8001=http://localhost:8001
URL_APP_8002=http://localhost:8002
URL_APP_8003=http://localhost:8003
URL_APP_8004=http://localhost:8004
URL_APP_8005=http://localhost:8005
URL_APP_8006=http://localhost:8006
URL_APP_8007=http://localhost:8007

# ── LIA ──────────────────────────────────────────────────────
ADMIN_PASSWORD=
DEBUG=False
SECRET_KEY=
# Em dev local: postgresql+asyncpg://lia:senha@localhost:5432/lia_db
DATABASE_URL=postgresql+asyncpg://lia:senha@postgres-pgvector:5432/lia_db
